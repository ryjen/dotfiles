#!/usr/bin/env bash

let INTERVAL=$SECONDS%15

if [[ $INTERVAL -ne 0 ]]; then
  exit 0
fi

VOLTAGE='⚡'

BAT1_FILE="/sys/class/power_supply/BAT1/capacity"
BAT0_FILE="/sys/class/power_supply/BAT0/capacity"

if [ "$(uname)" == "Darwin" ]; then
  battery_info=`pmset -g batt`
  current_charge=$(echo $battery_info | grep -o '[0-9]\+%' | awk '{sub (/%/, "", $1); print $1}')
elif [ -f $BAT1_FILE ]; then
  current_charge=`cat $BAT1_FILE`
elif [ -f $BAT0_FILE ]; then
  current_charge=`cat $BAT0_FILE`
else
  exit 0
fi

if [[ $current_charge -lt 30 ]]; then
    echo -n '#[fg=colour9]'
elif [[ $current_charge -lt 50 ]]; then
    echo -n '#[fg=colour184]'
elif [[ $current_charge -lt 70 ]]; then
    echo -n '#[fg=colour190]'
elif [[ $current_charge -lt 90 ]]; then
    echo -n '#[fg=colour226]'
else
    echo -n '#[fg=colour11]'
fi

echo -n "$VOLTAGE ${current_charge}%"
