#!/usr/bin/env bash

##
# use and temp file to persist across shells and for performance
##
ENV_FILE=/tmp/internet_info.env

## source the file variables
if [ -f $ENV_FILE ]; then
  source $ENV_FILE
fi

EPOCH=$(date +%s)

##
# get the modified time of the environment file
##
let INTERVAL=$EPOCH-$(stat -c "%Y" $ENV_FILE)

# reset every 24 hours
if [[ $INTERVAL -gt 86400 ]]; then
  unset PUBLIC_IP
  unset LOCAL_IP
  unset WIFI_STRENGTH
else
  ##
  # only check wifi on intervals
  ##
  INTERVAL=$(($EPOCH % 15))

  if [[ $INTERVAL -eq 0 ]]; then
    unset WIFI_STRENGTH
  fi
fi

##
# get the local ip and wifi signal strength
##
if [ "$(uname)" == "Darwin" ]; then
  if [ -z "$LOCAL_IP" ]; then
    LOCAL_IP=$(ipconfig getifaddr en0)
    RESET_ENV=1
  fi
  if [ -z "$WIFI_STRENGTH" ]; then
    WIFI_STRENGTH=`airport -I | grep agrCtlRSSI | awk '{print $2}' | sed 's/-//g'`
    RESET_ENV=1
  fi
else
  if [ -z "$LOCAL_IP" ] || [ -z "$WIFI_STRENGTH" ]; then
    WIFI=$(iwgetid | cut -d ' ' -f 1)
  fi
  if [ -z "$LOCAL_IP" ]; then
    LOCAL_IP=$(ifconfig $WIFI | grep 'inet ' | xargs | cut -d ' ' -f 2)
    RESET_ENV=1
  fi
  if [ -z "$WIFI_STRENGTH" ]; then
    WIFI_STRENGTH=`iwconfig $WIFI | grep 'Signal' | cut -d '=' -f3 | cut -d ' ' -f1`
    RESET_ENV=1
  fi
fi

##
# reset public ip if needed
##
if [ -z "$PUBLIC_IP" ]; then
  PUBLIC_IP=$(curl ifconfig.me)
  RESET_ENV=1
fi

##
# write the environment file if needed
##
if [[ $RESET_ENV -eq 1 ]]; then
  echo "PUBLIC_IP=$PUBLIC_IP" > $ENV_FILE
  echo "LOCAL_IP=$LOCAL_IP" >> $ENV_FILE
  echo "WIFI_STRENGTH=$WIFI_STRENGTH" >> $ENV_FILE
fi

INTERNET='🌎'

if [ ! -z "$WIFI_STRENGTH" ]; then
  if [[ $WIFI_STRENGTH -lt -20 ]]; then
    echo -n '#[fg=colour116]'
  elif [[ $WIFI_STRENGTH -lt -30 ]]; then
    echo -n '#[fg=colour117]'
  elif [[ $WIFI_STRENGTH -lt -40 ]]; then
    echo -n '#[fg=colour118]'
  elif [[ $WIFI_STRENGTH -lt -50 ]]; then
    echo -n '#[fg=colour119]'
  else
    echo -n '#[fg=colour120]'
  fi

  echo -n "${INTERNET} ${WIFI_STRENGTH}db "
fi
echo -n "#[fg=colour197]$LOCAL_IP #[fg=colour213]$PUBLIC_IP"

