#!/usr/bin/env bash

##
# use and temp file to persist across shells and for performance
##
ENV_FILE=/tmp/internet_info.env

## source the file variables
if [ -f $ENV_FILE ]; then
  source $ENV_FILE
fi

##
# only run every 10 seconds
##
let INTERVAL=$SECONDS%15

# and has run at least once
if [[ $INTERVAL -ne 0 ]] && [ ! -z "$PUBLIC_IP" ] && [ ! -z "$LOCAL_IP" ]; then
  exit 0
fi

##
# reset the values every 24 hours
##
let INTERVAL=$SECONDS-$(stat -c "%Y" $ENV_FILE)

if [[ $INTERVAL -gt 86400 ]]; then
  unset PUBLIC_IP
  unset LOCAL_IP
fi

##
# get the local ip and wifi signal strength
##
if [ "$(uname)" == "Darwin" ]; then
  if [ -z "$LOCAL_IP" ]; then
    LOCAL_IP=$(ipconfig getifaddr en0)
    RESET_ENV=1
  fi
  strength=`airport -I | grep agrCtlRSSI | awk '{print $2}' | sed 's/-//g'`
else
  WIFI=$(iwgetid | cut -d ' ' -f 1)
  if [ -z "$LOCAL_IP" ]; then
    LOCAL_IP=$(ifconfig $WIFI | grep 'inet ' | xargs | cut -d ' ' -f 2)
    RESET_ENV=1
  fi
  strength=`iwconfig $WIFI | grep 'Signal' | cut -d '=' -f3 | cut -d ' ' -f1`
fi

##
# reset public ip if needed
##
if [ -z "$PUBLIC_IP" ]; then
  PUBLIC_IP=$(curl ifconfig.me)
  RESET_ENV=1
fi

##
# write the environment file if needed
##
if [[ $RESET_ENV -eq 1 ]]; then
  echo "PUBLIC_IP=$PUBLIC_IP" > $ENV_FILE
  echo "LOCAL_IP=$LOCAL_IP" >> $ENV_FILE
fi

INTERNET='🌎'

if [ ! -z "$strength" ]; then
  if [[ $strength -lt -20 ]]; then
    echo -n '#[fg=colour116]'
  elif [[ $strength -lt -30 ]]; then
    echo -n '#[fg=colour117]'
  elif [[ $strength -lt -40 ]]; then
    echo -n '#[fg=colour118]'
  elif [[ $strength -lt -50 ]]; then
    echo -n '#[fg=colour119]'
  else
    echo -n '#[fg=colour120]'
  fi

  echo -n "${INTERNET} ${strength}db "
fi
echo -n "#[fg=colour197]$LOCAL_IP #[fg=colour213]$PUBLIC_IP"

