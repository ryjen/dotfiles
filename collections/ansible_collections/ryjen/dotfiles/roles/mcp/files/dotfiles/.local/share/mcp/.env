# Example .env file for MCP services
# This file should be placed in the same directory as docker-compose.yml
# and added to your .gitignore file to prevent committing sensitive data.

# Kaggle MCP Service
KAGGLE_USERNAME=your_kaggle_username
KAGGLE_KEY=your_kaggle_api_key

# MobSF MCP Service
MOBSF_API_KEY=your_mobsf_api_key
MOBSF_URL=your_mobsf_url_instance