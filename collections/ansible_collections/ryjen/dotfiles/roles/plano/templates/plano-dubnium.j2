#!/usr/bin/env bash
set -euo pipefail

CONFIG_FILE="${PLANO_CONFIG_FILE:-{{ plano_config_file }}}"

case "${1:-up}" in
  up)
    exec planoai up "$CONFIG_FILE"
    ;;
  build)
    exec planoai build "$CONFIG_FILE"
    ;;
  logs)
    exec planoai logs --follow
    ;;
  config)
    printf '%s\n' "$CONFIG_FILE"
    ;;
  *)
    exec planoai "$@"
    ;;
esac
