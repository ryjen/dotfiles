#!/bin/sh

OPTIND=1

while getopts "o:n:e:" opt; do
    case "$opt" in
    o) OLD_EMAIL="$OPTARG"
        ;;
    n) CORRECT_NAME="$OPTARG"
        ;;
    e) CORRECT_EMAIL="$OPTARG"
        ;;
    esac
done

if [ -z "$OLD_EMAIL" ]; then
    echo "Reset which email?"
    exit 1
fi

if [ -z "$CORRECT_EMAIL" ]; then
    DOMAIN=`domainname`
    if [ -z "$DOMAIN" ]; then
        DOMAINE=`hostname`
    fi
    CORRECT_EMAIL="$USER@$DOMAIN"
fi
if [ -z "$CORRECT_NAME" ]; then
    CORRECT_NAME="`dscl . -read $HOME RealName | sed -n 's/^ //g;2p'`"
fi

PROMPT="Reset '$OLD_EMAIL' to '$CORRECT_EMAIL <$CORRECT_NAME>'? (Y/n)"

read -n 1 -p "$PROMPT" c

if [ "$c" = "n" ] || [ "$c" = "N" ]; then
    exit 1
fi

export OLD_EMAIL
export CORRECT_EMAIL
export CORRECT_NAME

git filter-branch --commit-filter '
        if [ "$GIT_AUTHOR_EMAIL" = "$OLD_EMAIL" ];
        then
                GIT_AUTHOR_NAME="$CORRECT_NAME";
                GIT_AUTHOR_EMAIL="$CORRECT_EMAIL";
                git commit-tree "$@";
        else
                git commit-tree "$@";
        fi' HEAD


