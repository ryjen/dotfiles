#!/bin/sh

if [ -z "$1" ]; then
    echo "Reset which email?"
    exit 1
fi

DOMAIN=`domainname`
if [ -z "$DOMAIN" ]; then
    DOMAINE=`hostname`
fi
CORRECT_EMAIL="$USER@$DOMAIN"
CORRECT_NAME="`dscl . -read $HOME RealName | sed -n 's/^ //g;2p'`"

if [ ! -z "$2" ] && [ ! -z "$3" ]; then
    CORRECT_EMAIL=$2
    CORRECT_NAME=$3
fi

PROMPT="Reset author to $CORRECT_EMAIL <$CORRECT_NAME>? (Y/n)"

read -n 1 -p "$PROMPT" c

if [ "$c" = "n" ] || [ "$c" = "N" ]; then
    exit 1
fi

git filter-branch --env-filter 'if [ "$GIT_AUTHOR_EMAIL" = "$1" ]; then
     GIT_AUTHOR_EMAIL="$CORRECT_EMAIL";
     GIT_AUTHOR_NAME="$CORRECT_NAME";
     GIT_COMMITTER_EMAIL=$GIT_AUTHOR_EMAIL;
     GIT_COMMITTER_NAME="$GIT_AUTHOR_NAME"; fi' -- --all

