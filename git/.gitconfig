# Local/private config goes in the include
[include]
    path = ~/.config/.gitconfig.sec

[core]
    editor = vim
    excludesfile = ~/.gitignore

# From there, sections are in alphabetic order

[alias]
    last = log -1 HEAD
    co = checkout
    st = status
    uncommit = reset --soft HEAD~
    unstage = reset HEAD --
    lg = log --graph --abbrev-commit --decorate --date=relative --all

[difftool]
    prompt = false

[gui]
    # Remove `git gui` pop-up warning
    gcwarning = false

[help]
    autocorrect = 1

[mergetool]
    keepBackup = false
    prompt = false

[merge]
    tool = vimdiff
    conflictstyle = diff3

[pull]
    rebase = true

[push]
    default = simple

[rebase]
    autoStash = true

[commit]
    gpgsign = true

[gpg]
	program = gpg
