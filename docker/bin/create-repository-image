#!/usr/bin/env bash

while [[ $1 == -* ]]; do
  case "$1" in
    -f | --file)
      shift
      DOCKER_FILE=$1
      shift
      ;;
    -r | --repository)
      shift
      REPOSITORY=$1
      shift
      ;;
  esac
done

DOCKER_FILE=${DOCKER_FILE:-Dockerfile}
IMAGE_SLUG="$1"

shift

WORKING_DIR=${1:-.}

function syntax() {
  echo "Syntax: $(basename $0) [<options>] <image> [working dir]"
  echo ""
  echo "Options:"
  echo ""
  echo "  -f, --file        <file>    the docker file relative to the working dir"
  echo "  -r, --repository  <domain>  the remote repository base url"
  echo ""
}

if [ -z "${IMAGE_SLUG}" ]; then
  syntax
  exit 1
fi

echo "Building ${IMAGE_SLUG} with ${DOCKER_FILE} in ${WORKING_DIR}"

docker build -t ${IMAGE_SLUG} -f ${DOCKER_FILE} ${WORKING_DIR}

if [ ! -z "${REPOSITORY}" ]; then
  REMOTE_IMAGE="${REPOSITORY}/${IMAGE_SLUG}"
  docker tag ${IMAGE_SLUG} ${REMOTE_IMAGE}
  docker push ${REMOTE_IMAGE}
fi
