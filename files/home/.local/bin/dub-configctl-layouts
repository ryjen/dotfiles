#!/usr/bin/env bash
set -euo pipefail

# Waybar custom module for configctl-managed home configuration layers.
# Emits compact JSON so Waybar can show whether local/custom/adopted
# fragments exist for each managed tool without opening a terminal.

profile="${DUBNIUM_PROFILE:-dubnium}"
icon="󰙅"

json_escape() {
  python3 -c 'import json, sys; print(json.dumps(sys.stdin.read().strip()))'
}

emit_json() {
  local text="$1"
  local alt="$2"
  local class="$3"
  local tooltip="$4"

  printf '{"text":%s,"alt":%s,"class":%s,"tooltip":%s}\n' \
    "$(printf '%s' "$text" | json_escape)" \
    "$(printf '%s' "$alt" | json_escape)" \
    "$(printf '%s' "$class" | json_escape)" \
    "$(printf '%s' "$tooltip" | json_escape)"
}

if ! command -v configctl >/dev/null 2>&1; then
  emit_json "$icon missing" "missing" "critical" "configctl not found in PATH"
  exit 0
fi

status="$(configctl status 2>&1 || true)"

if grep -q '^configctl:' <<<"$status"; then
  emit_json "$icon error" "error" "critical" "$status"
  exit 0
fi

tools=()
while IFS= read -r line; do
  if [[ "$line" =~ ^([a-z0-9_-]+)[[:space:]]\(profile:[[:space:]]([^\)]+)\) ]]; then
    tools+=("${BASH_REMATCH[1]}")
    profile="${BASH_REMATCH[2]}"
  fi
done <<<"$status"

tool_count="${#tools[@]}"
unpromoted_count="$(grep -c '^[[:space:]]*unpromoted:' <<<"$status" || true)"
missing_count="$(grep -c 'missing' <<<"$status" || true)"
custom_total="$(awk '/^[[:space:]]*custom:/ { total += $2 } END { print total + 0 }' <<<"$status")"

if (( missing_count > 0 )); then
  class="warning"
  alt="missing"
elif (( unpromoted_count > 0 )); then
  class="warning"
  alt="unpromoted"
else
  class="ok"
  alt="ok"
fi

text="$icon ${profile}:${tool_count}"
if (( custom_total > 0 )); then
  text="$text +${custom_total}"
fi

tooltip="configctl layout status\nprofile: ${profile}\ntools: ${tool_count}\ncustom fragments: ${custom_total}\nunpromoted tools: ${unpromoted_count}\nmissing markers: ${missing_count}\n\n${status}"

emit_json "$text" "$alt" "$class" "$tooltip"
