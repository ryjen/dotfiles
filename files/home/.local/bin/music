#!/usr/bin/env bash
set -euo pipefail

music_dir="${MPV_MUSIC_DIR:-${DUBNIUM_MUSIC_DIR:-$HOME/Music}}"

if [ "$#" -gt 0 ]; then
  exec mpv \
    --loop-playlist=inf \
    --save-position-on-quit \
    "$@"
fi

if [ ! -d "$music_dir" ]; then
  printf 'music directory not found: %s\n' "$music_dir" >&2
  exit 1
fi

exec mpv \
  --shuffle \
  --loop-playlist=inf \
  --save-position-on-quit \
  "$music_dir"
