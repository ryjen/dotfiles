#!/usr/bin/env bash
set -euo pipefail

wallpaper_dir="$HOME/Pictures/wallpaper"

IMG=$(
  find -L "$wallpaper_dir" \
    -type f \
    \( -iname '*.jpg' -o -iname '*.jpeg' -o -iname '*.png' -o -iname '*.webp' -o -iname '*.jxl' \) \
    | shuf -n 1
)

if [ -z "$IMG" ]; then
  exit 1
fi

sleep 0.3

hyprctl hyprpaper wallpaper ",$IMG,cover"
