prefix_rule(pattern=["/bin/zsh", "-lc", "python - <<'PY'\nimport base64, json, urllib.request\n\ndef get(path):\n    url = f\"http://localhost:15672{path}\"\n    req = urllib.request.Request(url)\n    auth = base64.b64encode(b\"guest:guest\").decode(\"utf-8\")\n    req.add_header(\"Authorization\", f\"Basic {auth}\")\n    with urllib.request.urlopen(req, timeout=10) as resp:\n        return json.loads(resp.read().decode(\"utf-8\"))\n\nfor q in [\"anthesis.dispatch\", \"anthesis.dispatch.local\", \"anthesis.dispatch.n8n\"]:\n    payload = get(f\"/api/queues/%2F/{q}\")\n    print(q, \"messages=\", payload.get(\"messages\"), \"consumers=\", payload.get(\"consumers\"), \"args=\", payload.get(\"arguments\"))\n\nexchange = get(\"/api/exchanges/%2F/anthesis.dispatch\")\nprint(\"exchange type\", exchange.get(\"type\"))\n\nbindings = get(\"/api/exchanges/%2F/anthesis.dispatch/bindings/source\")\nprint(\"bindings\", [\n    {\"destination\": b.get(\"destination\"), \"destination_type\": b.get(\"destination_type\"), \"routing_key\": b.get(\"routing_key\")}\n    for b in bindings\n])\nPY"], decision="allow")
