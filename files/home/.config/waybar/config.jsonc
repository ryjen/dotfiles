// -*- mode: jsonc -*-
{
    "layer": "top",
    "position": "top",
    "spacing": 10,
    "height": 42,
    "exclusive": true,
    "passthrough": false,
    "fixed-center": true,
    "ipc": true,
    "modules-left": [
        "hyprland/workspaces",
        "hyprland/submap",
        "custom/media"
    ],
    "modules-center": [
        "hyprland/window"
    ],
    "modules-right": [
        "mpris",
        "idle_inhibitor",
        "pulseaudio",
        "power-profiles-daemon",
        "cpu",
        "memory",
        "temperature",
        "custom/nvidia-gpu",
        "custom/backlight",
        "battery",
        "clock",
        "tray",
        "hyprland/language",
        "custom/power"
    ],
    "hyprland/workspaces": {
        "disable-scroll": true,
        "all-outputs": true,
        "active-only": false,
        "format": "{name}: {icon}",
        "format-icons": {
            "1": "ï„ ",
            "2": "ï‰¨",
            "3": "ï„،",
            "urgent": "ïپھ",
            "active": "ï†’",
            "default": "ï„‘"
        }
    },
    "hyprland/window": {
        "format": "{title}",
        "max-length": 40,
        "separate-outputs": true,
        "rewrite": {
            "(.*) â€” Mozilla Firefox": "َ°ˆ¹ Firefox",
            "(.*) - Visual Studio Code": "َ°¨‍ Code",
            "(.*) - Alacritty": "ï’‰ Terminal",
            "": "Desktop"
        }
    },
    "hyprland/language": {
        "format": "ï„œ  {}",
        "format-en": "US",
        "format-colemak": "CMK",
        "on-click": "hyprctl switchxkblayout all next"
    },
    "hyprland/submap": {
        "format": "<span style=\"italic\">{}</span>"
    },
    "cpu": {
        "format": "{usage}% ï‹›",
        "on-click": "alacritty --title 'btop' -e sh -c 'btop'"
    },
    "memory": {
        "format": "{}% ïƒ‰",
        "on-click": "alacritty --title 'btop' -e sh -c 'btop'"
    },
    "backlight": {
        "device": "intel_backlight",
        "format": "{icon} {percent}%",
        "format-icons": ["îژچ", "îڈ“", "îڈ‘", "îڈڈ", "îڈژ", "îڈچ", "îڈٹ", "îڈˆ", "îژ›"],
        "on-scroll-up": "brightnessctl set 1%+",
        "on-scroll-down": "brightnessctl set 1%-",
        "min-length": 6
    },
    "custom/backlight": {
        "exec": "brightnessctl -m | cut -d, -f4",
        "interval": 1,
        "format": "َ°ƒ  {}",
        "on-scroll-up": "brightnessctl set 1%+",
        "on-scroll-down": "brightnessctl set 1%-",
        "tooltip": false
    },
    "temperature": {
        "critical-threshold": 80,
        "format": "{icon} {temperatureC}آ°C",
        "format-icons": ["ï‹‹", "ï‹ٹ", "ï‹‰", "ï‹ˆ", "ï‹‡"]
    },
    "custom/nvidia-gpu": {
        "exec": "~/.config/waybar/scripts/nvidia-gpu",
        "interval": 5,
        "return-type": "json",
        "format": "{}",
        "tooltip": true
    },
    "mpris": {
        "format": "{player_icon} {dynamic}",
        "format-paused": "{status_icon} <i>{dynamic}</i>",
        "player-icons": {
            "default": "â–¶",
            "spotify": "ï†¼",
            "firefox": "ï‰©",
            "chrome": "ï‰¨"
        },
        "status-icons": {
            "paused": "âڈ¸"
        },
        "max-length": 30
    },
    "battery": {
        "states": {
            "good": 95,
            "warning": 30,
            "critical": 15
        },
        "format": "{icon} {capacity}%",
        "format-charging": "َ°‚„ {capacity}%",
        "format-plugged": "ï‡¦ {capacity}%",
        "format-discharging": "{icon} {capacity}%",
        "format-full": "َ°پ¹ {capacity}%",
        "format-icons": ["َ°‚ژ", "َ°پ؛", "َ°پ»", "َ°پ¼", "َ°پ½", "َ°پ¾", "َ°پ؟", "َ°‚€", "َ°‚پ", "َ°‚‚", "َ°پ¹"],
        "on-click": "alacritty -e sudo powertop",
        "tooltip": true,
        "interval": 5,
        "bat": "BAT0"
    },
    "pulseaudio": {
        "format": "{volume}% {icon} {format_source}",
        "format-bluetooth": "{volume}% {icon}ïٹ” {format_source}",
        "format-muted": "ïڑ© {format_source}",
        "format-source": "{volume}% ï„°",
        "format-source-muted": "ï„±",
        "format-icons": {
            "headphone": "ï€¥",
            "default": ["ï€¦", "ï€§", "ï€¨"]
        },
        "on-click": "pavucontrol"
    },
    "network": {
        "format-wifi": "{essid} ({signalStrength}%) ï‡«",
        "format-ethernet": "{ipaddr}/{cidr} ï‍–",
        "tooltip-format": "{ifname} via {gwaddr} ï‍–",
        "format-disconnected": "Disconnected âڑ ",
        "on-click": "nm-connection-editor"
    },
    "idle_inhibitor": {
        "format": "<span font='12'>{icon}</span>",
        "format-icons": {
            "activated": "َ°›گ",
            "deactivated": "َ°›‘"
        },
        "tooltip": true
    },
    "clock": {
        "format": "{:%I:%M %p}",
        "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>",
        "on-click": "gsimplecal"
    },
    "custom/media": {
        "format": "{icon} {}",
        "return-type": "json",
        "max-length": 40,
        "format-icons": {
            "spotify": "ï†¼",
            "default": "ًںژœ"
        },
        "escape": true,
        "exec": "playerctl -a metadata --format '{\"text\": \"{{artist}} - {{title}}\", \"alt\": \"{{status}}\", \"class\": \"{{status}}\"}' --follow"
    },
    "custom/power": {
        "format": "âڈ» ",
        "on-click": "wlogout"
    }
}
