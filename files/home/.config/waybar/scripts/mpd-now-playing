#!/usr/bin/env bash
set -euo pipefail

mpc_bin="${MPC:-mpc}"
jq_bin="${JQ:-jq}"
host="${MPD_HOST:-127.0.0.1}"
port="${MPD_PORT:-6600}"

emit() {
  local text="$1"
  local class="$2"
  local alt="$3"
  local tooltip="$4"

  if command -v "$jq_bin" >/dev/null 2>&1; then
    "$jq_bin" -nc \
      --arg text "$text" \
      --arg class "$class" \
      --arg alt "$alt" \
      --arg tooltip "$tooltip" \
      '{text: $text, class: $class, alt: $alt, tooltip: $tooltip}'
  else
    printf '{"text":"%s","class":"%s","alt":"%s","tooltip":"%s"}\n' \
      "$text" "$class" "$alt" "$tooltip"
  fi
}

if ! command -v "$mpc_bin" >/dev/null 2>&1; then
  emit "mpd unavailable" "unavailable" "unavailable" "mpc is not installed or not in PATH"
  exit 0
fi

current="$($mpc_bin -h "$host" -p "$port" --format '%artist% - %title%' current 2>/dev/null || true)"
status="$($mpc_bin -h "$host" -p "$port" status 2>/dev/null || true)"

if [ -z "$status" ]; then
  emit "mpd offline" "offline" "offline" "MPD is not reachable at ${host}:${port}"
  exit 0
fi

state="$(printf '%s\n' "$status" | sed -n 's/^\[\([^]]*\)\].*/\1/p' | head -n 1)"
state="${state:-stopped}"

case "$state" in
  playing)
    icon="󰐊"
    class="playing"
    ;;
  paused)
    icon="󰏤"
    class="paused"
    ;;
  *)
    icon="󰓛"
    class="stopped"
    ;;
esac

if [ -z "$current" ]; then
  emit "${icon} mpd idle" "$class" "$state" "MPD: no current track"
else
  emit "${icon} ${current}" "$class" "$state" "${status}"
fi
